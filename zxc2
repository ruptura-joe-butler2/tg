# ── main ──────────────────────────────────────────────────────────────────────

if __name__ == '__main__':
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    host = sys.argv[1]

    if host == 'decode':
        ior_str = sys.argv[2]
        ior = parse_ior_str(ior_str)
        print_ior(ior)
        sys.exit(0)

    port_str = sys.argv[2]
    mode = sys.argv[3] if len(sys.argv) > 3 else 'namelist'

    if mode == 'namelist':
        port = int(port_str)
        do_namelist(host, port)

    elif mode == 'locate':
        port = int(port_str)
        keys = sys.argv[4:] if len(sys.argv) > 4 else COMMON_KEYS
        print("[*] LocateRequest probing %s:%d (%d keys)" % (host, port, len(keys)))
        print("    NOTE: port 2809 returns OBJECT_HERE for everything — not meaningful there")
        for key in keys:
            key_bytes = key.encode('ascii') if isinstance(key, str) else key
            status, _, fwd = locate_request(host, port, key_bytes)
            marker = '[+]' if status == 'OBJECT_HERE' else ('[ ]' if status == 'UNKNOWN_OBJECT' else '[~]')
            print("  %s %-40s %s" % (marker, key, status))
            if fwd:
                print_ior(fwd)

    elif mode == 'naming':
        port = int(port_str)
        print("[*] Naming service bootstrap on %s:%d" % (host, port))
        try_bootstrap_naming(host, port)

    elif mode in ('invoke', 'follow'):
        port = int(port_str)
        if len(sys.argv) < 6:
            print("Usage: %s <host> <port> invoke <key> <op> [arg]" % sys.argv[0])
            sys.exit(1)
        key = sys.argv[4]
        op  = sys.argv[5]
        arg = sys.argv[6] if len(sys.argv) > 6 else None
        invoke_operation(host, port, key, op, arg, follow=(mode == 'follow'))

    else:
        print("Unknown mode: %s" % mode)
        sys.exit(1)
